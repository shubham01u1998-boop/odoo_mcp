ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=your@email.com
ODOO_API_KEY=your_api_key_here

# --- HTTP / ngrok mode (optional) ---
# Set MCP_TRANSPORT=sse to run an HTTP server instead of stdio.
# Then tunnel with: ngrok http --host-header=rewrite 8000
# MCP_TRANSPORT=sse
# FASTMCP_PORT=8000
# FASTMCP_HOST=127.0.0.1  # set to 0.0.0.0 to bind all interfaces (Docker/VM)

# Per-user token map — maps bearer tokens to Odoo credentials so each user's actions
# are attributed to their own Odoo account (create_uid, write_uid, etc.).
# Claude Desktop: use Authorization: Bearer <token> header
# claude.ai web:  paste https://<ngrok>.ngrok-free.app/sse?token=<token> into the URL field
#
# To add a user:
#   1. Have them generate an Odoo API key: Odoo → avatar → My Profile → Account Security → API Keys
#   2. Generate a bearer token: python -c "import secrets; print(secrets.token_hex(32))"
#   3. Add an entry below
#
# MCP_TOKEN_MAP={"token1": {"username": "alice@example.com", "api_key": "odoo_key_1"}, "token2": {"username": "bob@example.com", "api_key": "odoo_key_2"}}
#
# Backward-compat single-token mode (all actions attributed to ODOO_USERNAME above):
# MCP_AUTH_TOKEN=your_secret_token_here
